{
  "name": "portal-backend",
  "version": "1.0.0",
  "description": "PWIOI Placement Portal Backend - Migrated from Firebase",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "prisma generate",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "node scripts/setupRenderDatabase.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:delete-all": "node scripts/deleteAllData.js",
    "db:create-students": "node scripts/createStudents.js",
    "db:add-profile-data": "node scripts/addStudentProfileData.js",
    "db:add-single-student": "node scripts/addSingleStudent.js",
    "db:create-admin": "node scripts/createAdmin.js",
    "db:fix-endorsements": "node scripts/fixEndorsements.js",
    "db:create-jobs": "node scripts/createRealisticJobs.js",
    "db:verify-job-updates": "node scripts/verifyJobDateUpdates.js",
    "db:mark-applicants": "node scripts/markAllApplicants.js",
    "db:diagnose-round": "node scripts/diagnoseInterviewRound.js",
    "db:fix-interview": "node scripts/fixInterviewSystem.js",
    "db:deep-diagnose": "node scripts/deepDiagnoseRoundIssue.js",
    "db:update-drive-date": "node scripts/updateJobDriveDate.js",
    "db:check-screening": "node scripts/checkScreeningStatus.js",
    "db:fix-screening": "node scripts/fixScreeningFinalization.js",
    "db:check-qualified": "node scripts/checkJobQualifiedCandidates.js",
    "db:create-applications": "node scripts/createTestApplications.js",
    "db:baseline": "prisma migrate resolve --applied",
    "worker": "node src/workers/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:google-ai": "node test-google-ai.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.5.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.0.0",
    "puppeteer-core": "^24.31.0",
    "socket.io": "^4.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "tsx": "^4.21.0"
  }
}
